@app.post("/chat/image")
async def chat_image(
    file: UploadFile = File(...),
    session_id: str = Form(None)
):
    if not session_id:
        session_id = str(uuid4())

    content = await file.read()
    image_b64 = base64.b64encode(content).decode("utf-8")

    logger.info(f"Processing image upload for session {session_id}")

    # Step 1: Try VLM extraction
    logger.info("Step 1: Attempting VLM extraction")
    extracted = extract_question_and_diagram_fallback(image_b64=image_b64)
    qtext = (extracted.get("question_text") or "").strip()
    diag = (extracted.get("diagram_description") or "").strip()

    # Step 2: If VLM failed, use OCR as fallback
    if not qtext:
        logger.info("Step 2: VLM extraction returned empty, falling back to OCR")
        
        suffix = "." + (file.filename.split(".")[-1] if "." in file.filename else "png")
        with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
            tmp.write(content)
            tmp_path = tmp.name
        
        logger.info(f"Running OCR on temporary image: {tmp_path}")
        qtext = (ocr_image(tmp_path) or "").strip()
        
        # Cleanup temp file
        try:
            import os as os_module
            os_module.unlink(tmp_path)
            logger.debug(f"Cleaned up temporary file: {tmp_path}")
        except Exception as e:
            logger.warning(f"Failed to cleanup temp file: {e}")

    # Step 3: Final validation
    if not qtext:
        logger.error(f"Failed to extract question text from image for session {session_id}")
        return {
            "error": True,
            "answer": (
                "I couldn't extract the question from the image. "
                "Please ensure:\n"
                "1. The image is clear and well-lit\n"
                "2. The question text is visible and not cropped\n"
                "3. The image is a standard textbook page or exam paper\n\n"
                "You can also type the question manually for better results."
            ),
            "session_id": session_id
        }

    logger.info(f"Successfully extracted question ({len(qtext)} chars): {qtext[:100]}...")

    # Step 4: Generate the answer
    # Load session memory
    session = load_session(session_id)
    chat_context = build_chat_context(session)

    logger.info("Generating answer with LLM")

    # Generate raw LLM answer
    raw_answer = generate_step_by_step_fallback(
        user_question=qtext,
        book_context="",
        chat_context=chat_context,
        diagram_description=diag
    )

    # CBSE formatted answer
    final_answer = build_final_answer(
        book_context="",
        step_by_step=raw_answer
    )

    # Save formatted answer to session
    update_session(session_id, qtext, final_answer)

    logger.info(f"Successfully generated answer for session {session_id}")

    return {
        "error": False,
        "answer": final_answer,
        "session_id": session_id,
        "extracted_question": qtext[:100] + ("..." if len(qtext) > 100 else "")
    }



# -------------------------------------------------
# Helpers
# -------------------------------------------------
def looks_like_generic_solver_query(q: str) -> bool:
    ql = (q or "").lower()

    if re.search(r"\bexercise\b|\bex\.\b|\bq\.\b|\bquestion\b", ql):
        return False

    if re.search(r"\bsolve\b|\bfind\s+[xy]\b", ql):
        return True

    if re.search(r"[0-9a-z]\s*=\s*[0-9a-z]", ql):
        return True

    return False


# -------------------------------------------------
# TEXT CHAT
# -------------------------------------------------
@app.post("/chat/text")
def chat_text(
    question: str = Form(...),
    session_id: str = Form(None)
):
    question = (question or "").strip()
    if not question:
        return {"answer": "Type a question."}

    if not session_id:
        session_id = str(uuid4())

    # Load session memory
    session = load_session(session_id)
    chat_context = build_chat_context(session)

    # Generate raw LLM answer
    raw_answer = generate_step_by_step_fallback(
        user_question=question,
        book_context="",
        chat_context=chat_context
    )

    # CBSE formatted answer
    final_answer = build_final_answer(
        book_context="",
        step_by_step=raw_answer
    )

    # Save formatted answer to session
    update_session(session_id, question, final_answer)

    return {
        "answer": final_answer,
        "session_id": session_id
    }


# -------------------------------------------------
# IMAGE CHAT
# -------------------------------------------------
@app.post("/chat/image")
async def chat_image(
    file: UploadFile = File(...),
    session_id: str = Form(None)
):
    if not session_id:
        session_id = str(uuid4())

    content = await file.read()
    image_b64 = base64.b64encode(content).decode("utf-8")

    extracted = extract_question_and_diagram_fallback(image_b64=image_b64)
    qtext = (extracted.get("question_text") or "").strip()
    diag = (extracted.get("diagram_description") or "").strip()

    if not qtext:
        suffix = "." + (file.filename.split(".")[-1] if "." in file.filename else "png")
        with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
            tmp.write(content)
            qtext = (ocr_image(tmp.name) or "").strip()

    if not qtext:
        return {
            "answer": (
                "I couldn’t automatically extract text from the image. "
                "Please crop the image or type the question."
            )
        }

    # Load session memory
    session = load_session(session_id)
    chat_context = build_chat_context(session)

    # Generate raw LLM answer
    raw_answer = generate_step_by_step_fallback(
        user_question=qtext,
        book_context="",
        chat_context=chat_context,
        diagram_description=diag
    )

    # CBSE formatted answer
    final_answer = build_final_answer(
        book_context="",
        step_by_step=raw_answer
    )

    # Save formatted answer to session
    update_session(session_id, qtext, final_answer)

    return {
        "answer": final_answer,
        "session_id": session_id
    }
